{
  "entities": {
    "Profile": {
      "title": "Streamer Profile",
      "description": "Configuration and settings for a streamer",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "bio": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "balance": { "type": "number" },
        "totalEarnings": { "type": "number" },
        "obsToken": { "type": "string" },
        "statsVisible": { "type": "boolean" },
        "minDonation": { "type": "number" },
        "maxDonation": { "type": "number" },
        "discordWebhook": { "type": "string" },
        "moderationWords": { "type": "array", "items": { "type": "string" } },
        "theme": { "type": "string" },
        "socials": {
          "type": "object",
          "properties": {
            "instagram": { "type": "string" },
            "youtube": { "type": "string" },
            "tiktok": { "type": "string" }
          }
        },
        "subscriptionsEnabled": { "type": "boolean" },
        "goal": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "title": { "type": "string" },
            "targetAmount": { "type": "number" },
            "currentAmount": { "type": "number" },
            "startDate": { "type": "string" },
            "endDate": { "type": "string" },
            "barThickness": { "type": "number" },
            "barColor": { "type": "string" },
            "barBgColor": { "type": "string" },
            "fontFamily": { "type": "string" },
            "fontColor": { "type": "string" }
          }
        },
        "alertSettings": {
          "type": "object",
          "properties": {
            "duration": { "type": "number" },
            "imageSize": { "type": "number" },
            "ttsEnabled": { "type": "boolean" },
            "soundUrl": { "type": "string" },
            "soundVolume": { "type": "number" },
            "senderFont": { "$ref": "FontSettings" },
            "messageFont": { "$ref": "FontSettings" },
            "amountFont": { "$ref": "FontSettings" }
          }
        }
      }
    },
    "FontSettings": {
      "title": "Font Settings",
      "type": "object",
      "properties": {
        "family": { "type": "string" },
        "size": { "type": "number" },
        "color": { "type": "string" },
        "style": { "type": "string" }
      }
    },
    "Alert": {
      "title": "Stream Alert",
      "description": "A donation or subscription alert",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["donation", "subscription"] },
        "receiver": { "type": "string" },
        "sender": { "type": "string" },
        "amount": { "type": "number" },
        "message": { "type": "string" },
        "tierName": { "type": "string" },
        "timestamp": { "type": "number" }
      }
    }
  },
  "firestore": {
    "/profiles/{username}": {
      "schema": "Profile",
      "description": "Streamer profile settings"
    },
    "/alerts/{alertId}": {
      "schema": "Alert",
      "description": "Real-time alerts for overlays"
    }
  }
}
